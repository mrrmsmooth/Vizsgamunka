Router_5

enable
configure terminal
ipv6 unicast-routing

interface gigabitEthernet 0/0/0
    ipv6 enable
    no shutdown
    ip nat outside
    ip address 99.99.92.2 255.255.255.252
    ipv6 address 7a4c:15e9::2/126
    exit
interface gigabitEthernet 0/0
    ipv6 enable
    no shutdown
interface gigabitEthernet 0/0.110
    encapsulation dot1Q 110
    ipv6 enable
    ipv6 address 2a02:ab8:4521:110::1/64
    ip address 10.1.110.1 255.255.255.0
    ip nat inside
interface gigabitEthernet 0/0.120
    encapsulation dot1Q 120
    ipv6 enable
    ipv6 address 2a02:ab8:4521:120::1/64
    ip address 10.1.120.1 255.255.255.0
    ip nat inside
interface gigabitEthernet 0/0.130
    encapsulation dot1Q 130
    ipv6 enable
    ipv6 address 2a02:ab8:4521:130::1/64
    ip address 10.1.130.1 255.255.255.0
    ip nat inside
    

ipv6 route ::/0 gigabitEthernet0/0/0
ip route 0.0.0.0 0.0.0.0 99.99.92.1

ip access-list standard NAT-LAN
    permit 10.0.0.0 0.255.255.255
ip nat pool NATPOOL 193.128.44.1 193.128.44.14 netmask 255.255.255.240
ip nat inside source list NAT-LAN pool NATPOOL overload

ip dhcp excluded-address 10.1.120.1
ip dhcp excluded-address 10.1.130.1

ip dhcp pool belso
        network 10.1.120.0 255.255.255.0
        default-router 10.1.120.1
        dns-server 193.128.40.1

ip dhcp pool wifi
        network 10.1.130.0 255.255.255.0
        default-router 10.1.130.1
        dns-server 193.128.40.1

ip access-list extended ONLY_OUTSIDE_WIFI
    permit udp any any eq 67
    permit udp any any eq 68
    permit udp 10.1.130.0 0.0.0.255 host 193.128.40.1 eq domain
    deny ip 10.1.130.0 0.0.0.255 10.0.0.0 0.255.255.255
    permit ip 10.1.130.0 0.0.0.255 any
    exit

interface gigabitEthernet 0/0.130
    ip access-group ONLY_OUTSIDE_WIFI in
    exit