switch_5

enable
configure terminal
ip default-gateway 10.3.116.1
vlan 116
name Management3
in vlan 116
ip address 10.3.116.2 255.255.255.0
exit
vlan 165
name FactoryOffice2
in vlan 165
exit

interface gigabitEthernet 0/1
switchport mode trunk
switchport trunk allowed vlan 116,165
no shutdown

interface range fastEthernet 0/1-24
switchport mode access
switchport access vlan 165
