Router_2

enable
configure terminal

ip route 0.0.0.0 0.0.0.0 99.99.91.1
ip route 10.1.0.0 255.255.0.0 192.168.1.1 

interface Serial 0/2/1
    ip address 99.99.91.2 255.255.255.0
    no shutdown
    ip nat outside

interface Serial 0/3/0
    ip address 10.10.1.1 255.255.255.252
    no shutdown
    ip nat inside
    ip ospf network point-to-point

interface Serial 0/3/1
    ip address 10.10.1.5 255.255.255.252
    no shutdown
    ip nat inside
    ip ospf network point-to-point
exit

interface tunnel0
    ip address 192.168.1.2 255.255.255.252
    tunnel source serial0/2/1
    tunnel destination 99.99.90.2
exit

ip access-list standard NAT-LAN
    permit 10.2.0.0 0.0.255.255
    permit 10.3.0.0 0.0.255.255
ip nat pool NATPOOL 193.128.43.1 193.128.43.14 netmask 255.255.255.240
ip nat inside source list NAT-LAN pool NATPOOL overload

router ospf 1
    router-id 2.2.2.2
    default-information originate
    network 10.10.1.0 0.0.0.3 area 0
    network 10.10.1.4 0.0.0.3 area 0
    passive-interface default
    no passive-interface Gig0/0
    no passive-interface Gig0/1








!DINAMIC
!ip access-list standard NAT-LAN
!permit 10.2.0.0 0.0.255.255
!permit 10.3.0.0 0.0.255.255
!ip nat pool NATPOOL 193.128.43.1 193.128.43.14 netmask 255.255.255.240
!ip nat inside source list NAT-LAN pool NATPOOL overload

!NAT ACL
!ip access-list extended NAT-EXEMPT
! deny   ip 10.1.0.0 0.0.255.255 10.2.0.0 0.0.255.255
! deny   ip 10.1.0.0 0.0.255.255 10.3.0.0 0.0.255.255
! permit ip 10.1.0.0 0.0.255.255 any

 !router ospf 1
!    router-id 2.2.2.2
!    network 10.10.1.0 0.0.0.3 area 0
!    network 10.10.1.4 0.0.0.3 area 0
!    network 192.168.1.0 0.0.0.3 area 0
!    !network 193.128.43.0 0.0.0.15 area 0
!    network 10.2.0.0 0.0.255.255 area 0
!    network 10.3.0.0 0.0.255.255 area 0